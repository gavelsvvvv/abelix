POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Server / port
PORT=3000

# Polygon (or other EVM chain) — chain id used by the Etherscan v2 API
CHAIN_ID=137

# Public on-chain addresses for the Polymarket referral payout source
# and the USDC token contract on the chosen chain. REQUIRED — server will
# refuse to start without them. Kept out of source so the contracts can
# be rotated / repointed at testnets without a code change.
REWARD_ADDRESS=0x0000000000000000000000000000000000000000
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# API endpoints (optional overrides)
POLYGONSCAN_API=https://api.etherscan.io/v2/api
POLYMARKET_PROFILE_API=https://gamma-api.polymarket.com/profiles

# Polymarket data API (used by fetch-leaderboard.js)
POLYMARKET_DATA_HOST=data-api.polymarket.com
# Optional: pin to a specific IP (otherwise resolved via DNS)
# POLYMARKET_DATA_IP=
LEADERBOARD_BATCH_SIZE=10
LEADERBOARD_DELAY_MS=300

